{
  "description": "",
  "routerFlow": "main",
  "variables": {
    "messagesADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "keyAttributes": "id",
        "itemType": "page:messageType"
      }
    }
  },
  "metadata": {},
  "types": {
    "messageType": {
      "id": "string",
      "severity": "string",
      "category": "string",
      "summary": "string",
      "detail": "string",
      "timestamp": "string",
      "autoTimeout": "number"
    }
  },
  "eventListeners": {
    "navInvoiceBackup": {
  "chains": [
    {
      "chain": "NavInvoiceBackupChain"
    }
  ]
},
"navSearchHistory": {
  "chains": [
    {
      "chain": "NavSearchHistoryChain"
    }
  ]
},
"navMissingAttachments": {
  "chains": [
    {
      "chain": "NavMissingAttachmentsChain"
    }
  ]
},
    "buttonAction": {
      "chains": [
        {
          "chain": "ButtonActionChain1",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "hyperlinkClick": {
      "chains": [
        {
          "chain": "HyperlinkClickChain",
          "parameters": {
            "event": "{{$event}}"
          }
        }
      ]
    },
    "vbNotification": {
      "chains": [
        {
          "chain": "showNotification",
          "parameters": {
            "eventPayload": "{{ { id: $event.key, summary: $event.summary, detail: $event.message, severity: $event.type, autoTimeout: $event.displayMode === 'transient' ? 0 : -1 } }}"
          }
        }
      ]
    },
    "onMessageClose": {
      "chains": [
        {
          "chain": "closeNotificationHandler",
          "parameters": {
            "eventMessage": "{{ $event.detail.message }}"
          }
        }
      ]
    }

  },
  "imports": {
    "components": {
      "oj-button": {
        "path": "ojs/ojbutton"
      },
      "oj-drawer-popup": {
        "path": "ojs/ojdrawerpopup"
      },
      "oj-messages": {
        "path": "ojs/ojmessages"
      }

    },
    "css": [
      "/resources/css/shell.css"
    ]
  },
  "translations": {}
}